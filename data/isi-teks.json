{\n  "hero_title_1": "Feel good,",\n  "hero_title_2": "one moment",\n  "hero_title_3": "at a time",\n  "hero_description": "Meet Mochi, your adorable self-care buddy! Track moods, practice mindfulness, and build healthy habits — all wrapped in the coziest app experience.",\n  "hero_btn_1": "Get Started Free",\n  "hero_btn_2": "See How It Works",\n  "features_title": "Everything you need to feel your best",\n  "features_description": "Simple tools designed to help you build mindful habits and nurture your wellbeing every day.",\n  "feature_1_title": "Mood Tracking",\n  "feature_1_desc": "Log how you're feeling with cute emoji check-ins. Discover patterns over time and celebrate your emotional journey with beautiful insights.",\n  "feature_2_title": "Breathing Exercises",\n  "feature_2_desc": "Calm your mind with guided breathing techniques. Watch Mochi breathe along with you in soothing, synchronized animations.",\n  "feature_3_title": "Gratitude Journal",\n  "feature_3_desc": "Write down three good things each day. Build a treasure trove of happy memories to look back on whenever you need a smile.",\n  "feature_4_title": "Sleep Sounds",\n  "feature_4_desc": "Drift off to dreamland with cozy soundscapes. Rain, waves, forest ambience, and more peaceful melodies to help you rest.",\n  "feature_5_title": "Daily Affirmations",\n  "feature_5_desc": "Start each day with positive words from Mochi. Uplifting quotes and gentle reminders that you're doing amazing.",\n  "feature_6_title": "Habit Tracker",\n  "feature_6_desc": "Build healthy routines one check at a time. Track streaks, celebrate wins, and watch your progress bloom.",\n  "how_it_works_title": "Start feeling better in 3 easy steps",\n  "how_it_works_description": "No complicated setup. Just download, open, and let Mochi guide you to a calmer you.",\n  "step_1_title": "Download & Meet Mochi",\n  "step_1_desc": "Get the app for free and say hello to your new self-care buddy. Mochi is excited to meet you!",\n  "step_2_title": "Check In Daily",\n  "step_2_desc": "Spend just 2 minutes each day logging your mood and practicing a quick mindfulness exercise.",\n  "step_3_title": "Watch Yourself Bloom",\n  "step_3_desc": "Track your progress, unlock cute achievements, and see how small moments create big changes.",\n  "preview_title": "A cozy space just for you",\n  "preview_description": "Every screen is designed to bring you calm and joy. Take a look inside!",\n  "testimonials_title": "What our community says",\n  "testimonials_description": "Join thousands who've found their calm with Mochi Space.",\n  "testimonial_1": "Mochi is the cutest thing ever! I look forward to my daily check-ins now. It's made mindfulness actually fun.",\n  "testimonial_1_author": "Sarah K.",\n  "testimonial_1_role": "Designer & Mom of 2",\n  "testimonial_2": "As someone with anxiety, this app has been a game-changer. The breathing exercises help me calm down in minutes.",\n  "testimonial_2_author": "Marcus T.",\n  "testimonial_2_role": "Software Developer",\n  "testimonial_3": "I've tried so many wellness apps, but Mochi Space is the only one I've stuck with. It just feels like a warm hug!",\n  "testimonial_3_author": "Emily R.",\n  "testimonial_3_role": "Graduate Student",\n  "cta_title": "Ready to find your Mochi Space?",\n  "cta_description": "Download now and start your self-care journey with Mochi by your side. It's free, forever!",\n  "footer_description": "Your cozy self-care companion. Building mindful habits, one moment at a time. Made with 💕 for people who deserve a little more calm in their lives."\n}\n